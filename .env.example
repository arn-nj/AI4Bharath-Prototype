# .env.example — copy this file to .env and fill in your credentials
# -----------------------------------------------------------------------
# cp .env.example .env        (Linux / macOS)
# Copy-Item .env.example .env (Windows PowerShell)
# -----------------------------------------------------------------------
# The .env file is gitignored and must never be committed to source control.

# ── AWS credentials (optional if running on Lambda / EC2 with IAM role) ──
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_REGION=us-east-1

# ── Amazon Bedrock — LLM engine ─────────────────────────────────────────
BEDROCK_MODEL_ID=qwen.qwen3-30b-a3b

# ── S3 storage ───────────────────────────────────────────────────────────
S3_BUCKET_NAME=<your-s3-bucket-name>
S3_MODEL_PREFIX=models/
S3_RESULTS_PREFIX=results/
S3_DOCUMENTS_PREFIX=documents/

# ── Legacy Azure OpenAI (kept for reference — no longer used) ────────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
# AZURE_OPENAI_API_KEY=<your-api-key>
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
# AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
