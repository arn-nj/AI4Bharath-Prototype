# =============================================================================
# .gitignore — E-Waste Asset Lifecycle Optimizer
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.env.*
.venv/
venv/
env/
ENV/

# Test & coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Node / React / Vite
# ---------------------------------------------------------------------------
node_modules/
src/frontend/dist/
src/frontend/.env
src/frontend/.env.*
!src/frontend/.env.example
.npm/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# AWS / SAM
# ---------------------------------------------------------------------------
.aws-sam/
packaged.yaml
# samconfig.toml is intentionally committed (stores deploy defaults)

# ---------------------------------------------------------------------------
# IDE & OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Secrets / credentials
# ---------------------------------------------------------------------------
*.pem
*.key
*.cert
credentials
